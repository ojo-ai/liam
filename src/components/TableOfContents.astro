---
interface TocItem {
  label: string;
  href: string;
  children?: TocItem[];
}
interface Props {
  items: TocItem[];
  title?: string;
}
const { items, title = 'In This Article' } = Astro.props;
---
<nav aria-label={title}>
  <p>{title}</p>
  <ol>
    {items.map((item) => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
  </ol>
</nav>
